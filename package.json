{
  "name": "story-spark-ai",
  "private": true,
  "version": "1.0.0",
  "description": "Story Spark AI",
  "license": "MIT",
  "contributors": [
    {
      "name": "Charan Balaji",
      "email": "neelamapallicharanbalaji14@gmail.com",
      "url": "https://github.com/charanbalaji2005"
    }
  ],
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npx concurrently -n backend,frontend -c blue,green \"pnpm --filter story-spark-ai-backend run dev\" \"pnpm --filter story-spark-ai-frontend run dev\"",
    "dev:backend": "pnpm --filter story-spark-ai-backend run dev",
    "dev:frontend": "pnpm --filter story-spark-ai-frontend run dev",
    "build": "pnpm --filter story-spark-ai-backend run build && pnpm --filter story-spark-ai-frontend run build",
    "build:backend": "pnpm --filter story-spark-ai-backend run build",
    "build:frontend": "pnpm --filter story-spark-ai-frontend run build",
    "start:backend": "pnpm --filter story-spark-ai-backend run start",
    "start:frontend": "pnpm --filter story-spark-ai-frontend run start",
    "lint": "pnpm --filter story-spark-ai-frontend run lint"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "concurrently": "^9.1.2"
  },
  "overrides": {
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.17.33"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "socket.io": "^4.8.3"
  }
}
