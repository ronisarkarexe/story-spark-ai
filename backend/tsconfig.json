{
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/__tests__/**"],
  "compilerOptions": {
    "noEmitOnError": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "target": "es2016", 
    "module": "commonjs",                               
    "rootDir": "./src",                                  
    "outDir": "./dist",                                  
    "forceConsistentCasingInFileNames": true,            
    "strict": true                                      
  }
}